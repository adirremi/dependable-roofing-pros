---
import { site } from "../data/site";
import Icon from "./Icon.astro";
export interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = "Ready for a Roof You Can Depend On?",
  subtitle = `Get a free, no-obligation inspection and estimate from Chattanooga's trusted roofing team.`,
} = Astro.props;
---

<section class="relative overflow-hidden bg-brand-600">
  <div
    class="absolute inset-0 opacity-15"
    style="background-image: radial-gradient(circle at 20% 20%, #fff 0, transparent 40%), radial-gradient(circle at 80% 0, #fff 0, transparent 35%);"
  >
  </div>
  <div
    class="container-x relative py-14 flex flex-col lg:flex-row items-center justify-between gap-8 text-center lg:text-left"
  >
    <div>
      <h2 class="font-display text-3xl md:text-4xl font-extrabold text-white">
        {title}
      </h2>
      <p class="mt-3 text-brand-50/90 text-lg max-w-2xl">{subtitle}</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 shrink-0">
      <a href={site.phoneHref} class="btn bg-white text-brand-700 hover:bg-brand-50">
        <Icon name="phone" class="w-5 h-5" /> {site.phone}
      </a>
      <a href="/contact" class="btn btn-dark">
        Free Estimate <Icon name="arrow" class="w-5 h-5" />
      </a>
    </div>
  </div>
</section>
