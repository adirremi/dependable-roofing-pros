---
export interface Props {
  name: string;
  class?: string;
}
const { name, class: className = "w-6 h-6" } = Astro.props;

// Stroke-based icons (Lucide-style). All use currentColor.
const paths: Record<string, string> = {
  home: '<path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/><path d="M9 21v-6h6v6"/>',
  wrench:
    '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.2L4 17l3 3 5.5-5.3a4 4 0 0 0 5.2-5.4l-2.5 2.5-2.3-2.3z"/>',
  storm:
    '<path d="M20 14.5A4.5 4.5 0 0 0 16 6.7 6 6 0 0 0 4.5 9 4 4 0 0 0 6 16.9"/><path d="m13 12-4 6h4l-1 4 4-6h-4z"/>',
  building:
    '<rect x="4" y="3" width="16" height="18" rx="1.5"/><path d="M9 8h.01M15 8h.01M9 12h.01M15 12h.01M9 16h.01M15 16h.01"/>',
  search:
    '<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>',
  layers:
    '<path d="m12 3 9 5-9 5-9-5 9-5z"/><path d="m3 13 9 5 9-5"/>',
  phone:
    '<path d="M6.6 3.5 9 8l-2.3 1.8a13 13 0 0 0 6.5 6.5L15 14l4.5 2.4a2 2 0 0 1 1 2.2 3.5 3.5 0 0 1-3.4 2.9A15.5 15.5 0 0 1 2.5 6.9 3.5 3.5 0 0 1 5.4 3.5a2 2 0 0 1 1.2 0z"/>',
  check:
    '<path d="M20 6 9 17l-5-5"/>',
  star: '<path d="m12 3 2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19l1-5.8L3.6 9.2l5.9-.9z"/>',
  clock:
    '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  pin: '<path d="M12 21s7-6.3 7-11a7 7 0 1 0-14 0c0 4.7 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  shield:
    '<path d="M12 3 5 6v6c0 4.4 3 7.6 7 9 4-1.4 7-4.6 7-9V6z"/><path d="m9 12 2 2 4-4"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  arrow: '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
  award:
    '<circle cx="12" cy="9" r="6"/><path d="m9 14-2 7 5-3 5 3-2-7"/>',
  money:
    '<rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 12h.01M18 12h.01"/>',
  users:
    '<circle cx="9" cy="8" r="3.5"/><path d="M3 20c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5"/><path d="M16 5.3a3.5 3.5 0 0 1 0 6.4M21 20c0-2.7-1.6-4.6-4-5.2"/>',
  leaf: '<path d="M4 20c0-9 6-15 16-15 0 10-6 16-16 15z"/><path d="M9 15c2-3 4-4 7-5"/>',
  quote:
    '<path d="M8 7H5a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2v2a2 2 0 0 1-2 2M20 7h-3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2v2a2 2 0 0 1-2 2"/>',
};

const inner = paths[name] ?? paths.check;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={inner}
/>
