---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";

const title = "Roofing Service Areas | Coral Springs & South Florida";
const description = `Dependable Roofing Pros serves Coral Springs, Parkland, Coconut Creek, Margate, Tamarac, Sunrise, Plantation, Fort Lauderdale and nearby South Florida communities. Call ${site.phone}.`;

const cities = site.areas.map((a) => a.replace(", FL", ""));

const mapQuery = encodeURIComponent(
  `${site.address.street}, ${site.address.city}, ${site.address.region} ${site.address.postalCode}`
);
---

<BaseLayout title={title} description={description} path="/service-areas">
  <PageHero
    eyebrow="Where We Work"
    title="Serving Coral Springs & South Florida"
    subtitle="Based in Coral Springs, we bring roofing services to homeowners and businesses across the surrounding South Florida communities."
    crumbs={[{ label: "Home", href: "/" }, { label: "Service Areas" }]}
  />

  <section class="py-20">
    <div class="container-x grid lg:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="font-display text-3xl font-extrabold text-ink-900">
          Communities We Serve
        </h2>
        <p class="mt-4 text-ink-600 text-lg">
          If you don't see your town listed, give us a call — we may cover your
          area too.
        </p>

        <div class="mt-8">
          <h3 class="flex items-center gap-2 font-display text-xl font-bold text-ink-900">
            <Icon name="pin" class="w-5 h-5 text-brand-600" /> South Florida
          </h3>
          <div class="mt-4 flex flex-wrap gap-2.5">
            {
              cities.map((c) => (
                <span class="inline-flex items-center gap-2 bg-ink-50 border border-ink-100 rounded-full px-4 py-2 text-sm font-medium text-ink-700">
                  <Icon name="check" class="w-4 h-4 text-brand-600" />
                  {c}
                </span>
              ))
            }
          </div>
        </div>

        <div class="mt-10 rounded-2xl bg-ink-950 text-white p-7">
          <h3 class="font-display text-xl font-bold">Not sure if we cover you?</h3>
          <p class="mt-2 text-ink-300 text-sm">
            Reach out and we'll let you know right away.
          </p>
          <a href={site.phoneHref} class="btn btn-primary mt-5">
            <Icon name="phone" class="w-5 h-5" /> {site.phone}
          </a>
        </div>
      </div>

      <div class="lg:sticky lg:top-28">
        <div class="rounded-2xl overflow-hidden border border-ink-100 shadow-lg">
          <iframe
            title="Dependable Roofing Pros location map"
            width="100%"
            height="480"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
          ></iframe>
        </div>
        <div class="mt-4 flex items-start gap-3 text-ink-600">
          <Icon name="pin" class="w-5 h-5 text-brand-600 shrink-0 mt-0.5" />
          <p>
            {site.address.street}, {site.address.city}, {site.address.region}
            {site.address.postalCode}
          </p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
