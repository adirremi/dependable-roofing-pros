---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
import { services } from "../data/services";

const title = "Contact Us | Roofing Estimate in Coral Springs, FL";
const description = `Contact Dependable Roofing Pros in Coral Springs, FL. Call ${site.phone} or request an estimate online for roof repair, replacement or installation in South Florida.`;

const contactPoints = [
  { icon: "phone", label: "Call Us", value: site.phone, href: site.phoneHref },
  { icon: "mail", label: "Text Us", value: site.phone, href: site.smsHref },
  {
    icon: "pin",
    label: "Visit Us",
    value: `${site.address.street}, ${site.address.city}, ${site.address.region} ${site.address.postalCode}`,
    href: undefined as string | undefined,
  },
];
---

<BaseLayout title={title} description={description} path="/contact">
  <PageHero
    eyebrow="Let's Talk"
    title="Contact Dependable Roofing Pros"
    subtitle="Call us or fill out the form below and our team will get back to you to discuss your roofing project. We're happy to answer any questions."
    crumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]}
  />

  <section class="py-20">
    <div class="container-x grid lg:grid-cols-5 gap-12">
      <!-- Contact info -->
      <div class="lg:col-span-2 space-y-6">
        {
          contactPoints.map((c) => (
            <div class="flex gap-4 items-start bg-ink-50 rounded-2xl p-6 border border-ink-100">
              <span class="grid place-items-center w-12 h-12 shrink-0 rounded-xl bg-brand-600 text-white">
                <Icon name={c.icon} class="w-6 h-6" />
              </span>
              <div>
                <div class="text-sm font-semibold text-ink-500 uppercase tracking-wide">
                  {c.label}
                </div>
                {c.href ? (
                  <a
                    href={c.href}
                    class="mt-1 block font-display text-lg font-bold text-ink-900 hover:text-brand-600 break-words"
                  >
                    {c.value}
                  </a>
                ) : (
                  <div class="mt-1 font-display text-lg font-bold text-ink-900">
                    {c.value}
                  </div>
                )}
              </div>
            </div>
          ))
        }

        <div class="bg-ink-950 text-white rounded-2xl p-6">
          <h3 class="flex items-center gap-2 font-display text-lg font-bold">
            <Icon name="pin" class="w-5 h-5 text-brand-400" /> Serving South Florida
          </h3>
          <p class="mt-3 text-ink-300 text-sm">
            Based in Coral Springs, we serve homeowners and businesses across the
            surrounding South Florida communities. Text or call and we'll be glad
            to help.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mt-5">
            <a href={site.smsHref} class="btn btn-primary flex-1">
              <Icon name="mail" class="w-5 h-5" /> Text Us
            </a>
            <a href={site.phoneHref} class="btn btn-ghost flex-1">
              <Icon name="phone" class="w-5 h-5" /> Call
            </a>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-3">
        <div class="rounded-2xl border border-ink-100 shadow-lg p-7 sm:p-9">
          <h2 class="font-display text-2xl font-extrabold text-ink-900">
            Text Us Your Details
          </h2>
          <p class="mt-2 text-ink-500">
            Fill this out and tap send — it opens a ready-to-go text message to us
            with your details. No email needed.
          </p>
          <form class="mt-6 space-y-4" data-sms-to={site.sms}>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-ink-700 mb-1.5" for="name">
                  Full name *
                </label>
                <input
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-lg border border-ink-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-500"
                />
              </div>
              <div>
                <label class="block text-sm font-semibold text-ink-700 mb-1.5" for="phone">
                  Phone *
                </label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  required
                  class="w-full rounded-lg border border-ink-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-500"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold text-ink-700 mb-1.5" for="service">
                Service needed
              </label>
              <select
                id="service"
                name="service"
                class="w-full rounded-lg border border-ink-200 px-4 py-3 bg-white focus:outline-none focus:ring-2 focus:ring-brand-500"
              >
                <option value="">Select…</option>
                {services.map((s) => <option value={s.title}>{s.title}</option>)}
                <option value="Other">Other / Not sure</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-ink-700 mb-1.5" for="address">
                Property address
              </label>
              <input
                id="address"
                name="address"
                class="w-full rounded-lg border border-ink-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-500"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-ink-700 mb-1.5" for="message">
                How can we help?
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full rounded-lg border border-ink-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-500"
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full text-base">
              <Icon name="mail" class="w-5 h-5" /> Send Text Message
            </button>
            <p class="text-xs text-ink-400 text-center">
              This opens your messaging app with the text pre-filled. Prefer to
              call? {site.phone}.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
