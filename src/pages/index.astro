---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";
import { services } from "../data/services";
import { faqs } from "../data/faqs";

const title = `${site.name} | Roofing Contractor in Coral Springs, FL`;
const description = `Dependable Roofing Pros is a roofing contractor in Coral Springs, FL, offering roof repair, replacement and installation across South Florida. Call ${site.phone}.`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const highlights = [
  "Roof Repair",
  "Roof Replacement",
  "New Installation",
  "Storm & Hurricane Damage",
];

const whyUs = [
  {
    icon: "pin",
    title: "Local to Coral Springs",
    text: "A South Florida roofing contractor serving our own community and the surrounding area.",
  },
  {
    icon: "wrench",
    title: "Repairs to Replacements",
    text: "From leaks and storm damage to complete roof replacements, we handle it all.",
  },
  {
    icon: "storm",
    title: "Built for Florida Weather",
    text: "Roofing solutions suited to South Florida's sun, heavy rain and hurricane season.",
  },
  {
    icon: "users",
    title: "Honest, Reliable Service",
    text: "Clear communication and quality workmanship you can depend on.",
  },
];

const steps = [
  {
    n: "01",
    title: "Get in Touch",
    text: "Call us or send a message about your roofing needs.",
  },
  {
    n: "02",
    title: "On-Site Assessment",
    text: "We visit your property and take a close look at your roof.",
  },
  {
    n: "03",
    title: "Your Estimate",
    text: "We provide a clear written estimate for the work involved.",
  },
  {
    n: "04",
    title: "Quality Installation",
    text: "Our crew completes the work and cleans up when we're done.",
  },
];
---

<BaseLayout title={title} description={description} path="/" jsonLd={[faqSchema]}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-ink-950 text-white">
    <div
      class="absolute inset-0"
      style="background:
        radial-gradient(1200px 600px at 75% -10%, rgba(224,48,26,0.35), transparent 60%),
        linear-gradient(160deg, #0f172a 0%, #020617 100%);"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.08]"
      style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 44px 44px;"
    >
    </div>

    <div class="container-x relative grid lg:grid-cols-12 gap-10 py-16 md:py-24">
      <div class="lg:col-span-7 reveal">
        <span
          class="inline-flex items-center gap-2 rounded-full bg-white/10 border border-white/15 px-4 py-1.5 text-sm font-medium"
        >
          <Icon name="pin" class="w-4 h-4 text-brand-400" />
          Serving Coral Springs &amp; South Florida
        </span>
        <h1
          class="mt-6 font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl leading-[1.05]"
        >
          Coral Springs' <span class="text-brand-500">Dependable</span> Roofing
          Contractor
        </h1>
        <p class="mt-6 text-lg text-ink-300 max-w-xl">
          Dependable Roofing Pros provides roof repair, replacement and new
          installation for homes and businesses across South Florida — reliable
          service and quality workmanship you can count on.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="/contact" class="btn btn-primary text-base">
            Request an Estimate <Icon name="arrow" class="w-5 h-5" />
          </a>
          <a href={site.phoneHref} class="btn btn-ghost text-base">
            <Icon name="phone" class="w-5 h-5" /> {site.phone}
          </a>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
          <span class="flex items-center gap-2">
            <Icon name="check" class="w-5 h-5 text-brand-400" /> Residential &amp; Commercial
          </span>
          <span class="flex items-center gap-2">
            <Icon name="check" class="w-5 h-5 text-brand-400" /> Storm &amp; Hurricane Damage
          </span>
          <span class="flex items-center gap-2">
            <Icon name="check" class="w-5 h-5 text-brand-400" /> Local &amp; Reliable
          </span>
        </div>
      </div>

      <!-- Estimate card -->
      <div class="lg:col-span-5 reveal">
        <div
          class="rounded-2xl bg-white text-ink-800 p-6 sm:p-8 shadow-2xl shadow-black/40"
        >
          <h2 class="font-display text-2xl font-bold">Text Us Your Details</h2>
          <p class="text-ink-500 text-sm mt-1">
            Fill this out and tap send — it opens a ready-to-go text message to
            us. Fast and easy.
          </p>
          <form class="mt-5 space-y-3" data-sms-to={site.sms}>
            <div class="grid sm:grid-cols-2 gap-3">
              <input
                name="name"
                required
                placeholder="Full name"
                class="w-full rounded-lg border border-ink-200 px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
              />
              <input
                name="phone"
                type="tel"
                required
                placeholder="Phone"
                class="w-full rounded-lg border border-ink-200 px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
              />
            </div>
            <select
              name="service"
              class="w-full rounded-lg border border-ink-200 px-3.5 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-brand-500"
            >
              <option value="">Service needed…</option>
              {services.map((s) => <option value={s.title}>{s.title}</option>)}
            </select>
            <textarea
              name="message"
              rows="3"
              placeholder="Tell us about your project"
              class="w-full rounded-lg border border-ink-200 px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            ></textarea>
            <button type="submit" class="btn btn-primary w-full">
              <Icon name="mail" class="w-5 h-5" /> Send Text Message
            </button>
            <p class="text-[0.7rem] text-ink-400 text-center">
              Opens your texting app with a message ready to send. Prefer to call?
              {site.phone}.
            </p>
          </form>
        </div>
      </div>
    </div>

    <!-- Highlights strip -->
    <div class="relative border-t border-white/10">
      <div class="container-x grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
        {
          highlights.map((h) => (
            <div class="py-6 text-center flex items-center justify-center gap-2">
              <Icon name="check" class="w-5 h-5 text-brand-500" />
              <span class="font-semibold text-ink-100 text-sm sm:text-base">{h}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-20 bg-ink-50">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-brand-600 font-semibold tracking-wide uppercase text-sm">
          What We Do
        </p>
        <h2 class="mt-2 font-display text-3xl md:text-4xl font-extrabold text-ink-900">
          Complete Roofing Services
        </h2>
        <p class="mt-4 text-ink-600 text-lg">
          From repairs to full replacements, we handle roofing for homes and
          businesses across South Florida.
        </p>
      </div>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          services.map((s) => (
            <a
              href={s.href}
              class="group bg-white rounded-2xl p-7 border border-ink-100 hover:border-brand-200 hover:shadow-xl hover:shadow-ink-200/50 transition"
            >
              <span class="grid place-items-center w-14 h-14 rounded-xl bg-brand-50 text-brand-600 group-hover:bg-brand-600 group-hover:text-white transition">
                <Icon name={s.icon} class="w-7 h-7" />
              </span>
              <h3 class="mt-5 font-display text-xl font-bold text-ink-900">
                {s.title}
              </h3>
              <p class="mt-2 text-ink-600 text-sm leading-relaxed">{s.blurb}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-brand-600 font-semibold text-sm">
                Learn more
                <Icon name="arrow" class="w-4 h-4 group-hover:translate-x-1 transition" />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="py-20">
    <div class="container-x grid lg:grid-cols-2 gap-14 items-center">
      <div>
        <p class="text-brand-600 font-semibold tracking-wide uppercase text-sm">
          Why Choose Us
        </p>
        <h2 class="mt-2 font-display text-3xl md:text-4xl font-extrabold text-ink-900">
          Roofing Done Right
        </h2>
        <p class="mt-4 text-ink-600 text-lg">
          We're a locally based team that treats every roof with care. Our focus
          is honest service, quality workmanship, and results built for South
          Florida's climate.
        </p>
        <div class="mt-8 grid sm:grid-cols-2 gap-6">
          {
            whyUs.map((w) => (
              <div class="flex gap-4">
                <span class="grid place-items-center w-12 h-12 shrink-0 rounded-xl bg-ink-900 text-brand-400">
                  <Icon name={w.icon} class="w-6 h-6" />
                </span>
                <div>
                  <h3 class="font-bold text-ink-900">{w.title}</h3>
                  <p class="text-sm text-ink-600 mt-1">{w.text}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="relative">
        <div
          class="rounded-3xl bg-gradient-to-br from-ink-900 to-ink-950 p-8 sm:p-10 text-white overflow-hidden"
        >
          <Icon name="shield" class="w-14 h-14 text-brand-500" />
          <h3 class="mt-5 font-display text-2xl font-bold">
            The Dependable Difference
          </h3>
          <p class="mt-3 text-ink-300">
            We keep things simple and straightforward — quality materials,
            careful installation and clear communication from start to finish.
          </p>
          <ul class="mt-6 space-y-3">
            {
              [
                "Straightforward, no-pressure service",
                "Quality materials and careful installation",
                "Respectful crews who clean up after the job",
                "Clear communication throughout your project",
              ].map((item) => (
                <li class="flex items-center gap-3">
                  <Icon name="check" class="w-5 h-5 text-brand-400 shrink-0" />
                  <span class="text-ink-200">{item}</span>
                </li>
              ))
            }
          </ul>
          <a href="/about" class="btn btn-primary mt-8">
            More About Us <Icon name="arrow" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-20 bg-ink-950 text-white">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-brand-500 font-semibold tracking-wide uppercase text-sm">
          Our Process
        </p>
        <h2 class="mt-2 font-display text-3xl md:text-4xl font-extrabold">
          Simple &amp; Straightforward
        </h2>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          steps.map((s) => (
            <div class="relative rounded-2xl bg-white/5 border border-white/10 p-7">
              <span class="font-display text-4xl font-extrabold text-brand-500/40">
                {s.n}
              </span>
              <h3 class="mt-3 font-display text-xl font-bold">{s.title}</h3>
              <p class="mt-2 text-ink-400 text-sm">{s.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-ink-50">
    <div class="container-x max-w-3xl">
      <div class="text-center">
        <p class="text-brand-600 font-semibold tracking-wide uppercase text-sm">
          FAQ
        </p>
        <h2 class="mt-2 font-display text-3xl md:text-4xl font-extrabold text-ink-900">
          Frequently Asked Questions
        </h2>
      </div>
      <div class="mt-10 space-y-3">
        {
          faqs.map((f) => (
            <details class="group bg-white rounded-xl border border-ink-100 p-5">
              <summary class="flex items-center justify-between cursor-pointer font-semibold text-ink-900 list-none">
                {f.q}
                <span class="text-brand-600 text-2xl group-open:rotate-45 transition">
                  +
                </span>
              </summary>
              <p class="mt-3 text-ink-600 leading-relaxed">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
