---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
import { services } from "../data/services";

const title = `Roofing Services in Coral Springs, FL`;
const description = `Full-service roofing in Coral Springs & South Florida: roof replacement, repair, storm & hurricane damage, commercial roofing, inspections & gutters. Call ${site.phone}.`;

const serviceListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: services.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: s.title,
    url: new URL(s.href, site.url).href,
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  path="/services"
  jsonLd={[serviceListSchema]}
>
  <PageHero
    eyebrow="Full-Service Roofing Contractor"
    title="Roofing Services Built to Protect What Matters"
    subtitle={`From emergency repairs to complete replacements, Dependable Roofing Pros delivers quality workmanship for homes and businesses across Coral Springs and South Florida.`}
    crumbs={[{ label: "Home", href: "/" }, { label: "Services" }]}
  />

  <section class="py-20">
    <div class="container-x grid gap-8">
      {
        services.map((s, i) => (
          <div
            id={s.slug}
            class="grid lg:grid-cols-12 gap-8 items-center bg-ink-50 rounded-3xl p-8 md:p-10 border border-ink-100 scroll-mt-24"
          >
            <div class={`lg:col-span-7 ${i % 2 === 1 ? "lg:order-2" : ""}`}>
              <span class="grid place-items-center w-14 h-14 rounded-xl bg-brand-600 text-white">
                <Icon name={s.icon} class="w-7 h-7" />
              </span>
              <h2 class="mt-5 font-display text-2xl md:text-3xl font-extrabold text-ink-900">
                {s.title}
              </h2>
              <p class="mt-3 text-ink-600 text-lg">{s.blurb}</p>
              <ul class="mt-6 grid sm:grid-cols-2 gap-3">
                {s.points.map((p) => (
                  <li class="flex items-center gap-3">
                    <Icon name="check" class="w-5 h-5 text-brand-600 shrink-0" />
                    <span class="text-ink-700">{p}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-7 flex flex-wrap gap-3">
                <a href="/contact" class="btn btn-primary">
                  Request an Estimate <Icon name="arrow" class="w-4 h-4" />
                </a>
                {(s.slug === "roof-replacement" ||
                  s.slug === "roof-repair") && (
                  <a href={s.href} class="btn btn-dark">
                    Learn More
                  </a>
                )}
              </div>
            </div>
            <div class={`lg:col-span-5 ${i % 2 === 1 ? "lg:order-1" : ""}`}>
              <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-ink-900 to-ink-800 grid place-items-center text-brand-500/70">
                <Icon name={s.icon} class="w-28 h-28" />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <CtaBand />
</BaseLayout>
