---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
import { services } from "../data/services";

const title = `About ${site.name} | Coral Springs Roofing Contractor`;
const description = `Dependable Roofing Pros is a roofing contractor in Coral Springs, FL, serving homeowners and businesses across South Florida with roof repair, replacement and installation.`;

const values = [
  { icon: "shield", title: "Integrity First", text: "We give honest recommendations and straightforward service on every project." },
  { icon: "award", title: "Quality Workmanship", text: "We use quality materials and careful installation on every roof." },
  { icon: "users", title: "Community", text: "We're based in Coral Springs and proud to serve our South Florida neighbors." },
  { icon: "clock", title: "Reliability", text: "We communicate clearly and follow through on what we start." },
];

const chooseUs = [
  "Locally based in Coral Springs",
  "Residential & commercial roofing",
  "Roofing built for South Florida weather",
  "Honest, straightforward service",
  "Quality materials & careful installation",
  "Respectful crews who clean up",
];
---

<BaseLayout title={title} description={description} path="/about">
  <PageHero
    eyebrow="Roofing Contractor in Coral Springs, FL"
    title="About Dependable Roofing Pros"
    subtitle="We're a South Florida roofing contractor focused on honest service, quality workmanship, and roofs built to handle Florida's weather."
    crumbs={[{ label: "Home", href: "/" }, { label: "About" }]}
  />

  <section class="py-20">
    <div class="container-x grid lg:grid-cols-2 gap-14 items-center">
      <div>
        <p class="text-brand-600 font-semibold tracking-wide uppercase text-sm">
          Who We Are
        </p>
        <h2 class="mt-2 font-display text-3xl md:text-4xl font-extrabold text-ink-900">
          Craftsmanship, Reliability &amp; Straightforward Service
        </h2>
        <div class="mt-5 space-y-4 text-ink-600 text-lg leading-relaxed">
          <p>
            Dependable Roofing Pros is a roofing contractor based in Coral
            Springs, Florida. We provide roof repair, roof replacement and new
            roof installation for homeowners and businesses throughout South
            Florida.
          </p>
          <p>
            Whether it's a repair, a full replacement, or ongoing maintenance, we
            approach every project with the same commitment to quality and
            reliable service. Our goal is simple: dependable roofing that helps
            keep your property protected.
          </p>
          <p>
            South Florida weather can be demanding, so we focus on roofing that's
            built to handle the sun, heavy rain and hurricane season — installed
            with care and clear communication throughout.
          </p>
        </div>
        <a href="/contact" class="btn btn-primary mt-8">
          Work With Us <Icon name="arrow" class="w-4 h-4" />
        </a>
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        {
          services.slice(0, 4).map((s) => (
            <a
              href={s.href}
              class="rounded-2xl bg-ink-50 border border-ink-100 p-6 hover:border-brand-200 transition"
            >
              <span class="grid place-items-center w-12 h-12 rounded-xl bg-brand-600 text-white">
                <Icon name={s.icon} class="w-6 h-6" />
              </span>
              <h3 class="mt-4 font-bold text-ink-900">{s.title}</h3>
              <p class="mt-1.5 text-sm text-ink-600">{s.short}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-20 bg-ink-50">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-brand-600 font-semibold tracking-wide uppercase text-sm">
          What Drives Us
        </p>
        <h2 class="mt-2 font-display text-3xl md:text-4xl font-extrabold text-ink-900">
          Our Core Values
        </h2>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          values.map((v) => (
            <div class="bg-white rounded-2xl p-7 border border-ink-100">
              <span class="grid place-items-center w-14 h-14 rounded-xl bg-brand-600 text-white">
                <Icon name={v.icon} class="w-7 h-7" />
              </span>
              <h3 class="mt-5 font-display text-lg font-bold text-ink-900">
                {v.title}
              </h3>
              <p class="mt-2 text-ink-600 text-sm">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-x">
      <div
        class="rounded-3xl bg-gradient-to-br from-ink-900 to-ink-950 text-white p-10 md:p-14 grid lg:grid-cols-2 gap-10 items-center"
      >
        <div>
          <h2 class="font-display text-3xl font-extrabold">
            Why Choose Dependable Roofing Pros
          </h2>
          <p class="mt-4 text-ink-300 text-lg">
            We keep roofing simple and straightforward — quality work, clear
            communication, and a team that's local to South Florida.
          </p>
        </div>
        <ul class="grid sm:grid-cols-2 gap-4">
          {
            chooseUs.map((item) => (
              <li class="flex items-center gap-3">
                <Icon name="check" class="w-5 h-5 text-brand-400 shrink-0" />
                <span class="text-ink-200">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
